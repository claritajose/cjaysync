filters:
  and:
    - file.inFolder("DriveSyncFiles")
summaries:
  Batusin: file.name.contains(Batusin)
views:
  - type: table
    name: Table
    groupBy:
      property: Instructor
      direction: ASC
    order:
      - file.name
      - file.mtime
      - Instructor
    sort: []
    summaries:
      Instructor: Batusin
  - type: cards
    name: View
