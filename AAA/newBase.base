summaries:
  Batusin: file.name.split("-")[0].charAt(0).to
filters:
  and:
    - file.inFolder("DriveSyncFiles/Review files")
formulas:
  Untitled: file.name.split("-")[0]
properties:
  formula.Untitled:
    displayName: Instructor
views:
  - type: table
    name: Table
    groupBy:
      property: formula.Untitled
      direction: ASC
    order:
      - file.name
      - file.mtime
    sort: []
    summaries:
      Instructor: Batusin
  - type: cards
    name: View
