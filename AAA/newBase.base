summaries:
  new summary: file.name.split("-")
filters:
  and:
    - file.inFolder("DriveSyncFiles")
formulas:
  Untitled: file.name.split("-")[0]
properties:
  formula.Untitled:
    displayName: Instructor
views:
  - type: table
    name: Table
    groupBy:
      property: formula.Untitled
      direction: ASC
    order:
      - file.name
      - Subject
    sort: []
    summaries: {}
  - type: cards
    name: View
